 150:Core/Src/main.c **** void ICM_SPI_Write(uint8_t reg, uint8_t value)
 151:Core/Src/main.c **** {
 152:Core/Src/main.c ****     uint8_t tx[2];
 153:Core/Src/main.c **** 
 154:Core/Src/main.c ****     tx[0] = reg & 0x7F;   // SPI write
 155:Core/Src/main.c ****     tx[1] = value;
 156:Core/Src/main.c **** 
 157:Core/Src/main.c **** 
 158:Core/Src/main.c ****     HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_RESET);
 159:Core/Src/main.c **** 
 160:Core/Src/main.c ****     HAL_SPI_Transmit(&hspi1,
 161:Core/Src/main.c ****                      tx,
 162:Core/Src/main.c ****                      2,
 163:Core/Src/main.c ****                      100);
 164:Core/Src/main.c **** 
 165:Core/Src/main.c ****     HAL_GPIO_WritePin(GPIOA, GPIO_PIN_4, GPIO_PIN_SET);
 166:Core/Src/main.c **** }
