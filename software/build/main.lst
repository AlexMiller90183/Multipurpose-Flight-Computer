 168:Core/Src/main.c **** void Sensor_Check(void)
 169:Core/Src/main.c **** {
 170:Core/Src/main.c ****     uint8_t devices[] = {
 171:Core/Src/main.c ****         0x6B
 172:Core/Src/main.c ****     };
 173:Core/Src/main.c **** 
 174:Core/Src/main.c ****     printf("Checking sensors...\r\n");
 175:Core/Src/main.c **** 
 176:Core/Src/main.c ****     for(uint8_t i = 0; i < sizeof(devices); i++)
 177:Core/Src/main.c ****     {
 178:Core/Src/main.c ****         HAL_StatusTypeDef result;
 179:Core/Src/main.c **** 
 180:Core/Src/main.c ****         result = HAL_I2C_IsDeviceReady(&hi2c1, devices[i] << 1, 5, 100);
 181:Core/Src/main.c **** 
 182:Core/Src/main.c ****         if(result == HAL_OK)
 183:Core/Src/main.c ****         {
 184:Core/Src/main.c ****             printf("Sensor found at 0x%02X\r\n", devices[i]);
 185:Core/Src/main.c ****         }
 186:Core/Src/main.c ****         else
 187:Core/Src/main.c ****         {
 188:Core/Src/main.c ****             printf("No response at 0x%02X (HAL error %d)\r\n",
 189:Core/Src/main.c ****                    devices[i],
 190:Core/Src/main.c ****                    result);
 191:Core/Src/main.c ****         }
 192:Core/Src/main.c ****     }
 193:Core/Src/main.c **** 
 194:Core/Src/main.c ****     printf("Sensor check complete\r\n");
 195:Core/Src/main.c **** }
