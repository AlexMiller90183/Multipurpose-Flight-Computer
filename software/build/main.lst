  96:Core/Src/main.c **** void I2C_Scan(void)
  97:Core/Src/main.c **** {
  98:Core/Src/main.c ****     HAL_StatusTypeDef result;
  99:Core/Src/main.c **** 
 100:Core/Src/main.c ****     printf("Starting I2C scan...\r\n");
 101:Core/Src/main.c **** 
 102:Core/Src/main.c ****     for(uint8_t addr = 1; addr < 127; addr++)
 103:Core/Src/main.c ****     {
 104:Core/Src/main.c ****         printf("Checking 0x%02X\r\n", addr);
 105:Core/Src/main.c **** 
 106:Core/Src/main.c ****         result = HAL_I2C_IsDeviceReady(&hi2c1,
 107:Core/Src/main.c ****                                        addr << 1,
 108:Core/Src/main.c ****                                        3,
 109:Core/Src/main.c ****                                        100);
 110:Core/Src/main.c **** 
 111:Core/Src/main.c ****         printf("Result=%d\r\n", result);
 112:Core/Src/main.c **** 
 113:Core/Src/main.c ****         if(result == HAL_OK)
 114:Core/Src/main.c ****         {
 115:Core/Src/main.c ****             printf("Found device at 0x%02X\r\n", addr);
 116:Core/Src/main.c ****         }
 117:Core/Src/main.c **** 
 118:Core/Src/main.c ****         HAL_Delay(5);
 119:Core/Src/main.c ****     }
 120:Core/Src/main.c **** 
 121:Core/Src/main.c ****     printf("Done\r\n");
 122:Core/Src/main.c **** }
