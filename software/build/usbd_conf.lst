 236:USB_DEVICE/Target/usbd_conf.c **** {
 237:USB_DEVICE/Target/usbd_conf.c ****   /* Inform USB library that core enters in suspend Mode. */
 238:USB_DEVICE/Target/usbd_conf.c ****   USBD_LL_Suspend((USBD_HandleTypeDef*)hpcd->pData);
 239:USB_DEVICE/Target/usbd_conf.c ****   __HAL_PCD_GATE_PHYCLOCK(hpcd);
 240:USB_DEVICE/Target/usbd_conf.c ****   /* Enter in STOP mode. */
 241:USB_DEVICE/Target/usbd_conf.c ****   /* USER CODE BEGIN 2 */
 242:USB_DEVICE/Target/usbd_conf.c ****   if (hpcd->Init.low_power_enable)
 243:USB_DEVICE/Target/usbd_conf.c ****   {
 244:USB_DEVICE/Target/usbd_conf.c ****     /* Set SLEEPDEEP bit and SleepOnExit of Cortex System Control Register. */
 245:USB_DEVICE/Target/usbd_conf.c ****     SCB->SCR |= (uint32_t)((uint32_t)(SCB_SCR_SLEEPDEEP_Msk | SCB_SCR_SLEEPONEXIT_Msk));
