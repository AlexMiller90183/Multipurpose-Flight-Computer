 613:USB_DEVICE/Target/usbd_conf.c **** /**
 614:USB_DEVICE/Target/usbd_conf.c ****   * @brief  Send LPM message to user layer
 615:USB_DEVICE/Target/usbd_conf.c ****   * @param  hpcd: PCD handle
 616:USB_DEVICE/Target/usbd_conf.c ****   * @param  msg: LPM message
 617:USB_DEVICE/Target/usbd_conf.c ****   * @retval None
 618:USB_DEVICE/Target/usbd_conf.c ****   */
 619:USB_DEVICE/Target/usbd_conf.c **** void HAL_PCDEx_LPM_Callback(PCD_HandleTypeDef *hpcd, PCD_LPM_MsgTypeDef msg)
 620:USB_DEVICE/Target/usbd_conf.c **** {
 621:USB_DEVICE/Target/usbd_conf.c ****   switch (msg)
 622:USB_DEVICE/Target/usbd_conf.c ****   {
 623:USB_DEVICE/Target/usbd_conf.c ****   case PCD_LPM_L0_ACTIVE:
 624:USB_DEVICE/Target/usbd_conf.c ****     if (hpcd->Init.low_power_enable)
 625:USB_DEVICE/Target/usbd_conf.c ****     {
 626:USB_DEVICE/Target/usbd_conf.c ****       SystemClockConfig_Resume();
 627:USB_DEVICE/Target/usbd_conf.c **** 
 628:USB_DEVICE/Target/usbd_conf.c ****       /* Reset SLEEPDEEP bit of Cortex System Control Register. */
 629:USB_DEVICE/Target/usbd_conf.c ****       SCB->SCR &= (uint32_t)~((uint32_t)(SCB_SCR_SLEEPDEEP_Msk | SCB_SCR_SLEEPONEXIT_Msk));
 630:USB_DEVICE/Target/usbd_conf.c ****     }
 631:USB_DEVICE/Target/usbd_conf.c ****     __HAL_PCD_UNGATE_PHYCLOCK(hpcd);
 632:USB_DEVICE/Target/usbd_conf.c ****     USBD_LL_Resume(hpcd->pData);
 633:USB_DEVICE/Target/usbd_conf.c ****     break;
 634:USB_DEVICE/Target/usbd_conf.c **** 
 635:USB_DEVICE/Target/usbd_conf.c ****   case PCD_LPM_L1_ACTIVE:
 636:USB_DEVICE/Target/usbd_conf.c ****     __HAL_PCD_GATE_PHYCLOCK(hpcd);
 637:USB_DEVICE/Target/usbd_conf.c ****     USBD_LL_Suspend(hpcd->pData);
 638:USB_DEVICE/Target/usbd_conf.c **** 
 639:USB_DEVICE/Target/usbd_conf.c ****     /* Enter in STOP mode. */
 640:USB_DEVICE/Target/usbd_conf.c ****     if (hpcd->Init.low_power_enable)
 641:USB_DEVICE/Target/usbd_conf.c ****     {
 642:USB_DEVICE/Target/usbd_conf.c ****       /* Set SLEEPDEEP bit and SleepOnExit of Cortex System Control Register. */
 643:USB_DEVICE/Target/usbd_conf.c ****       SCB->SCR |= (uint32_t)((uint32_t)(SCB_SCR_SLEEPDEEP_Msk | SCB_SCR_SLEEPONEXIT_Msk));
 644:USB_DEVICE/Target/usbd_conf.c ****     }
 645:USB_DEVICE/Target/usbd_conf.c ****     break;
 646:USB_DEVICE/Target/usbd_conf.c ****   }
 647:USB_DEVICE/Target/usbd_conf.c **** }
